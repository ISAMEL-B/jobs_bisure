RewriteEngine On

# =========================================
# REMOVE .php EXTENSION
# =========================================
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L]

# =========================================
# REDIRECT .php URL TO CLEAN URL
# =========================================
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]